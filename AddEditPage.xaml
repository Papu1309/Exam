<Page x:Class="Exam.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Exam"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Тип"/>
                <ComboBox x:Name="ProductTypeCmb" SelectedItem = "{Binding IdProductType}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Наименование продукта"/>
                <TextBox Text="{Binding ProductName}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Артикул"/>
                <TextBox Text="{Binding Articule}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Минимальная стоимость для партнёра (р)"/>
                <TextBox Text="{Binding MinimalPrice}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Ширина (м)"/>
                <TextBox Text="{Binding RulonWidth}"/>
            </StackPanel>
        </StackPanel>
        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Grid.Row="1">
            <Button x:Name="SaveBtn" Click="SaveBtn_Click">Сохранить</Button>
            <Button x:Name="CanselBtn" Background="Red" Click="CanselBtn_Click">Назад</Button>
        </StackPanel>
    </Grid>
</Page>
